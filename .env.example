# ============================================================
# AI Character Chat — 환경변수 템플릿
# ============================================================
# 사용법: cp .env.example .env → 값 채우기
# ConfigModule.forRoot({ isGlobal: true }) 가 자동 로드
# ============================================================

# ── LLM API Keys ──────────────────────────────────────────
# Primary: Google Gemini 2.5 Pro
GEMINI_API_KEY=

# Fallback: Anthropic Claude Sonnet 4
ANTHROPIC_API_KEY=

# ── Service Ports ─────────────────────────────────────────
API_GATEWAY_PORT=3000
CHAT_SERVICE_URL=0.0.0.0:50051
IMAGE_SERVICE_URL=0.0.0.0:50052
EVENT_SERVICE_PORT=3002

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY=7d

# ── OAuth (Phase 1은 스텁 — 프로덕션에서 활성화) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3000/auth/kakao/callback

# ── Client Redirect ───────────────────────────────────────
CLIENT_REDIRECT_URL=http://localhost:3001

# ── Database (프로덕션용 — 로컬은 sql.js 자동) ───────────
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=
# DB_PASSWORD=
# DB_DATABASE=ai_character_chat

# ── Redis (Phase 2) ──────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Kafka (Phase 2) ──────────────────────────────────────
# KAFKA_BROKERS=localhost:9092

# ── CDN ──────────────────────────────────────────────────
# CDN_BASE_URL=https://cdn.example.com/assets
